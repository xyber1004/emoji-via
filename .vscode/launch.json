{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter (Debug Mode)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "debug"
        },
        {
            "name": "Flutter (Profile Mode)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "profile"
        },
        {
            "name": "Flutter (Release Mode)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "release"
        },
        {
            "name": "Flutter (Development Flavor)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main_dev.dart",
            "flutterMode": "debug",
            "args": [
                "--flavor", "development"
            ]
        },
        {
            "name": "Flutter (With Custom Env Args)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "flutterMode": "debug",
            "toolArgs": [
                "--dart-define", "API_BASE_URL=https://example.com",
                "--dart-define", "APP_THEME=dark"
            ]
        }
    ]
}